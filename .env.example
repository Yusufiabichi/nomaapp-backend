# Server Configuration
NODE_ENV=development
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://yusufiabichi:Yu3uX6$-EFh4Xme@cluster.mongodb.net/nomaapp?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# AI Service Configuration
AI_SERVICE_URL=http://localhost:1000
AI_SERVICE_API_KEY=your-ai-service-api-key
